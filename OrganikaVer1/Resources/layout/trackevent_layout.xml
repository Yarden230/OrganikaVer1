<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="10dp"
    android:gravity="center_vertical"
    android:background="#dcebfa">
    <TextView
        android:id="@+id/tvName"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="2"
        android:text="Event name"
        android:textColor="#333333"
        android:textSize="14sp" />

    <TextView
        android:id="@+id/tvAssignedTime"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1.5"
        android:text="assigned time"
        android:textColor="#333333"
        android:textSize="14sp" />

    <TextView
        android:id="@+id/tvScheduledHours"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1.5"
        android:text="SH / AH"
        android:textColor="#333333"
        android:textSize="14sp" />

    <TextView
        android:id="@+id/tvCompleted"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="2"
        android:text="C / AH completed"
        android:textColor="#333333"
        android:textSize="14sp" />

    <ImageView
        android:id="@+id/ivActionIcon"
        android:layout_width="0dp"
        android:layout_height="24dp"
        android:layout_weight="0.8"
        android:src="@android:drawable/ic_menu_preferences" android:contentDescription="Options"
        android:scaleType="centerInside" />

</LinearLayout>